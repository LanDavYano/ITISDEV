# ─── NextAuth ──────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace_with_a_random_secret_string
NEXTAUTH_URL=http://localhost:3000

# ─── MongoDB ───────────────────────────────────────────────────────────────
# Connection string used by database/db.js (Mongoose).
# Local MongoDB:
MONGODB_URI=mongodb://127.0.0.1:27017/aiesec_dlsu
# MongoDB Atlas (cloud) example:
# MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/aiesec_dlsu?retryWrites=true&w=majority

# ─── Email (Forgot Password) ────────────────────────────────────────────────
# Leave all EMAIL_* variables unset (or remove them) to use Ethereal Email in
# development — OTP emails are captured and a preview URL is printed to the
# server console. No account or config required.
#
# To use Gmail SMTP instead:
#   1. Enable 2-Step Verification on your Google account.
#   2. Go to Google Account → Security → App Passwords.
#   3. Generate an app password for "Mail" and paste it as EMAIL_PASS below.
#
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASS=your-16-char-app-password
